            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "RegisterUserDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
