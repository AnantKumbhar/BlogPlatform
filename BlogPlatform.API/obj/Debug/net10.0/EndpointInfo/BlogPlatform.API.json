      "CreateBlogDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "shortDescription": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "categoryId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
